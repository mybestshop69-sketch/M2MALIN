FLASK_SECRET_KEY=replace-with-a-long-random-value
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
APP_BASE_URL=http://localhost:5000
DATABASE_URL=sqlite:///data/m2malin_social.sqlite
TOKEN_ENCRYPTION_KEY=
DEFAULT_TIMEZONE=Europe/Paris
SCHEDULE_HOURS=12:00,18:00
HUMAN_APPROVAL_REQUIRED=true
AUTO_MODE_ENABLED=false

# Meta / Facebook / Instagram
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v23.0
META_REDIRECT_URI=http://localhost:5000/oauth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=
MESSENGER_AUTO_REPLY_ENABLED=true
M2MALIN_SITE_URL=https://m2malin.fr

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:5000/oauth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.publish,video.upload

# Optional branding
SHOP_NAME=M2 Malin
SHOP_URL=https://m2malin.fr
